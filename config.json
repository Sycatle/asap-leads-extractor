{
  "input_csv": "data/raw/export.csv",
  "target": 100,
  "allowed_departments": [
    "72",
    "49",
    "53",
    "44",
    "85"
  ],
  "exclude_keywords": [
    "Carrefour",
    "McDonald's",
    "Leclerc",
    "Auchan",
    "Intermarché"
  ],
  "scrape": {
    "niches": [
      "rénovation intérieure",
      "extension maison",
      "couvreur",
      "chauffagiste",
      "pompe à chaleur",
      "menuisier",
      "plombier",
      "électricien",
      "expert comptable",
      "avocat",
      "architecte intérieur",
      "paysagiste",
      "diagnostiqueur immobilier"
    ],
    "cities": [
      "Le Mans",
      "Paris",
      "Lyon",
      "Marseille",
      "Bordeaux",
      "Nantes"
    ]
  },
  "worker": {
    "interval_minutes": 30,
    "auto_export": true
  },
  "orchestrator": {
    "scrape_interval": 5,
    "enrich_interval": 1,
    "website_interval": 5,
    "collect_interval": 30,
    "max_scrape_per_cycle": 3,
    "max_enrich_per_cycle": 30,
    "max_website_per_cycle": 20,
    "enrich_priority_threshold": 50,
    "parallel_pipelines": true,
    "auto_throttle": true,
    "metrics_interval": 30
  }
}