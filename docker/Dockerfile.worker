# syntax=docker/dockerfile:1.7
# Multi-stage build pour le worker (scrapers Playwright + agent LLM)
FROM node:22-bookworm-slim AS base
ENV PNPM_HOME=/pnpm
ENV PATH=$PNPM_HOME:$PATH
RUN corepack enable && corepack prepare pnpm@10.15.0 --activate

# ===== INSTALL =====
FROM base AS deps
WORKDIR /app
COPY package.json pnpm-lock.yaml .npmrc ./
RUN --mount=type=cache,id=pnpm-store,target=/pnpm/store \
    pnpm install --frozen-lockfile --prod=false

# ===== RUNTIME =====
FROM mcr.microsoft.com/playwright:v1.57.0-noble AS runtime
ENV PNPM_HOME=/pnpm
ENV PATH=$PNPM_HOME:$PATH
ENV NODE_ENV=production
ENV DATABASE_URL=postgresql://leads:leads@postgres:5432/leads
RUN corepack enable && corepack prepare pnpm@10.15.0 --activate

WORKDIR /app

# Re-install runtime deps (chromium provient déjà de l'image base playwright)
COPY package.json pnpm-lock.yaml .npmrc ./
RUN --mount=type=cache,id=pnpm-store,target=/pnpm/store \
    pnpm install --frozen-lockfile --prod=false

# Code source
COPY tsconfig.json drizzle.config.ts ./
COPY db ./db
COPY shared ./shared
COPY worker ./worker

# Healthcheck léger : node check sur DB
HEALTHCHECK --interval=60s --timeout=10s --start-period=30s \
  CMD node -e "require('pg').Client && process.exit(0)" || exit 1

CMD ["pnpm", "worker"]
