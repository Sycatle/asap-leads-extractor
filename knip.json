{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "workspaces": {
    ".": {
      "entry": [
        "worker/index.ts",
        "worker/cli.ts",
        "worker/**/*.test.ts",
        "db/**/*.test.ts"
      ],
      "project": [
        "worker/**/*.ts",
        "shared/**/*.ts",
        "db/**/*.ts"
      ],
      "ignoreDependencies": ["knip"]
    },
    "web": {
      "entry": [
        "src/app/**/{page,layout,route,template,loading,error,not-found}.{ts,tsx}",
        "next.config.ts"
      ],
      "project": ["src/**/*.{ts,tsx}"],
      "ignoreDependencies": ["tailwindcss", "tw-animate-css"]
    }
  }
}
