# ===============================================
# Database
# ===============================================
DATABASE_URL=postgresql://leads:leads@localhost:5434/leads
POSTGRES_DB=leads
POSTGRES_USER=leads
POSTGRES_PASSWORD=leads

# ===============================================
# Web auth (REQUIRED in production)
# ===============================================
# Format: user1:password1,user2:password2
# If NODE_ENV=development and this is empty, auth is bypassed.
ALLOWED_USERS=

# ===============================================
# LLM agents (Anthropic / Claude)
# ===============================================
# https://console.anthropic.com
ANTHROPIC_API_KEY=
# Optional: model for legal-mentions extraction (default claude-opus-4-7)
LEGAL_AGENT_MODEL=claude-opus-4-7
# Optional: parallel legal pipelines (default 2)
LEGAL_CONCURRENCY=2
# Optional: rolling 30-day USD budget (0 or unset = unlimited)
LEGAL_BUDGET_USD=0
# Optional: model for inbound reply classification (default claude-haiku-4-5)
REPLY_CLASSIFIER_MODEL=claude-haiku-4-5

# ===============================================
# Enrichment (Pappers fallback)
# ===============================================
PAPPERS_API_KEY=

# ===============================================
# Outbound email (Resend)
# ===============================================
# https://resend.com
RESEND_API_KEY=
# Svix secret used to verify Resend webhook signatures
RESEND_WEBHOOK_SECRET=
# HMAC secret for one-click unsubscribe tokens (>= 16 chars)
UNSUB_TOKEN_SECRET=
# Public domain used to build unsubscribe URLs (e.g. app.example.com)
APP_DOMAIN=
# MX domain for inbound reply parsing (e.g. inbound.example.com)
INBOUND_DOMAIN=
# Address that receives sender-health alerts + positive-reply notifications
ADMIN_NOTIFY_EMAIL=
