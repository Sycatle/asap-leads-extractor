PAPPERS_API_KEY=votre_cle_ici

# ===============================================
# Authentification Web (OBLIGATOIRE en production)
# ===============================================
# Format: user1:password1,user2:password2
ALLOWED_USERS=

# ===============================================
# Agent LLM - Extraction mentions légales
# ===============================================
# Clé API Claude (https://console.anthropic.com)
ANTHROPIC_API_KEY=
# Optionnel: modèle (défaut claude-opus-4-7 ; alternatives: claude-haiku-4-5, claude-sonnet-4-6)
LEGAL_AGENT_MODEL=claude-opus-4-7
# Optionnel: nombre de leads traités en parallèle (défaut 2)
LEGAL_CONCURRENCY=2
# Optionnel: budget USD sur 30j glissants (0 ou non défini = pas de limite).
# Si dépassé, la pipeline arrête et logge un warning au prochain run.
LEGAL_BUDGET_USD=0