{
  "name": "leads-finder",
  "version": "3.0.0",
  "description": "Self-hosted B2B lead generation and outbound platform: Google Maps scraping, French company enrichment, multi-step email sequences with deliverability monitoring and AI reply classification.",
  "type": "module",
  "scripts": {
    "start": "tsx worker/index.ts orchestrator",
    "worker": "tsx worker/index.ts orchestrator",
    "full": "tsx worker/index.ts full",
    "once": "tsx worker/index.ts once",
    "cli": "tsx worker/cli.ts",
    "scrape": "tsx worker/index.ts scrape",
    "enrich": "tsx worker/index.ts enrich",
    "enrich:website": "tsx worker/index.ts enrich:website",
    "enrich:legal": "tsx worker/index.ts enrich:legal",
    "stats": "tsx worker/cli.ts stats",
    "migrate": "drizzle-kit migrate",
    "migrate:generate": "drizzle-kit generate",
    "migrate:push": "drizzle-kit push",
    "migrate:studio": "drizzle-kit studio",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose stop postgres",
    "web": "cd web && pnpm dev",
    "web:build": "cd web && pnpm build",
    "help": "tsx worker/index.ts help",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "keywords": [
    "b2b",
    "leads",
    "lead-generation",
    "outbound",
    "email-sequences",
    "scraping",
    "playwright",
    "drizzle",
    "postgres",
    "nextjs",
    "gdpr"
  ],
  "author": "sycatle <sycatle@pm.me>",
  "license": "Apache-2.0",
  "packageManager": "pnpm@10.15.0",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.1",
    "@types/pg": "^8.20.0",
    "@vitest/coverage-v8": "^4.1.7",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.4.1",
    "knip": "^6.14.2",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0",
    "vitest": "^4.1.7"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.96.0",
    "commander": "^14.0.3",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "p-limit": "^7.3.0",
    "pg": "^8.20.0",
    "playwright": "^1.60.0",
    "resend": "^6.12.3",
    "svix": "^1.93.0",
    "zod": "^4.4.3"
  }
}
