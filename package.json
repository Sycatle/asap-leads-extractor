{
  "name": "leads-finder",
  "version": "3.0.0",
  "description": "Lead generation tool with multi-pipeline worker, Postgres + Drizzle stack",
  "type": "module",
  "scripts": {
    "start": "tsx worker/index.ts orchestrator",
    "worker": "tsx worker/index.ts orchestrator",
    "full": "tsx worker/index.ts full",
    "once": "tsx worker/index.ts once",
    "cli": "tsx worker/cli.ts",
    "scrape": "tsx worker/index.ts scrape",
    "enrich": "tsx worker/index.ts enrich",
    "enrich:website": "tsx worker/index.ts enrich:website",
    "enrich:legal": "tsx worker/index.ts enrich:legal",
    "stats": "tsx worker/cli.ts stats",
    "migrate": "drizzle-kit migrate",
    "migrate:generate": "drizzle-kit generate",
    "migrate:push": "drizzle-kit push",
    "migrate:studio": "drizzle-kit studio",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose stop postgres",
    "web": "cd web && pnpm dev",
    "web:build": "cd web && pnpm build",
    "help": "tsx worker/index.ts help",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.15.0",
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^25.0.9",
    "@types/pg": "^8.20.0",
    "@vitest/coverage-v8": "^3.2.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.0.0",
    "knip": "^6.14.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.2.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.96.0",
    "commander": "^14.0.3",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "p-limit": "^7.3.0",
    "pg": "^8.20.0",
    "playwright": "^1.60.0",
    "resend": "^6.12.3",
    "svix": "^1.93.0",
    "zod": "^4.4.3"
  }
}
